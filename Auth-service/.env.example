# Server
PORT=5001   
NODE_ENV=development

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=budget
DB_USER=postgres
DB_PASSWORD=your_password

# Optionally use a full connection URL instead of the above
# DATABASE_URL=postgresql://postgres:your_password@localhost:5432/budget

# CORS — allowed frontend origin
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=your_super_secret_key
